    <script>
        const themeButton = document.getElementById("theme-toggle");
        const voiceButton = document.getElementById("voice-toggle");
        const contrastButton = document.getElementById("contrast-toggle");
        const fontDecrease = document.getElementById("font-decrease");
        const fontIncrease = document.getElementById("font-increase");

        /* tema */
        const savedTheme = localStorage.getItem("theme");

        if (savedTheme === "light") {
            document.body.classList.add("light");
            themeButton.textContent = "☀️";
        } else if (!savedTheme) {
            if (window.matchMedia("(prefers-color-scheme: light)").matches) {
                document.body.classList.add("light");
                themeButton.textContent = "☀️";
            }
        }

        themeButton.addEventListener("click", () => {
            document.body.classList.toggle("light");

            const isLight = document.body.classList.contains("light");

            themeButton.textContent = isLight ? "☀️" : "🌙";
            localStorage.setItem("theme", isLight ? "light" : "dark");
        });

        /* leitura por voz */
        let voiceEnabled = false;

        function speak(text) {
            if (!voiceEnabled) return;
            if (!text || !text.trim()) return;

            window.speechSynthesis.cancel();

            const speech = new SpeechSynthesisUtterance(text.trim());
            speech.lang = "pt-BR";
            speech.rate = 1;
            speech.pitch = 1;

            window.speechSynthesis.speak(speech);
        }

        voiceButton.addEventListener("click", () => {
            voiceEnabled = !voiceEnabled;

            voiceButton.textContent = voiceEnabled ? "🔈" : "🔊";

            if (!voiceEnabled) {
                window.speechSynthesis.cancel();
            } else {
                speak("Leitura ativada");
            }
        });

        document.querySelectorAll("a, button, h1, h2, h3, p, span").forEach((element) => {
            element.addEventListener("mouseenter", () => {
                const text = element.innerText || element.getAttribute("aria-label") || "";
                speak(text);
            });
        });

        /* contraste */
        const savedContrast = localStorage.getItem("contrast");

        if (savedContrast === "on") {
            document.body.classList.add("high-contrast");
        }

        contrastButton.addEventListener("click", () => {
            document.body.classList.toggle("high-contrast");

            const enabled = document.body.classList.contains("high-contrast");

            localStorage.setItem("contrast", enabled ? "on" : "off");
        });

        /* tamanho da fonte */
        let currentFont = parseInt(localStorage.getItem("fontSize"));

        if (currentFont) {
            document.documentElement.style.fontSize = currentFont + "%";
        }

        fontDecrease.addEventListener("click", () => {
            if (!currentFont) currentFont = 100;

            if (currentFont > 70) {
                currentFont -= 10;
                document.documentElement.style.fontSize = currentFont + "%";
                localStorage.setItem("fontSize", currentFont);
            }
        });

        fontIncrease.addEventListener("click", () => {
            if (!currentFont) currentFont = 100;

            if (currentFont < 130) {
                currentFont += 10;
                document.documentElement.style.fontSize = currentFont + "%";
                localStorage.setItem("fontSize", currentFont);
            }
        });
    </script>
